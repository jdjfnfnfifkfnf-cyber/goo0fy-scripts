local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local mouse = player:GetMouse()


local function createTool(character)

	local humanoid = character:WaitForChild("Humanoid")
	local root = character:WaitForChild("HumanoidRootPart")


	local oldGui = player.PlayerGui:FindFirstChild("GoofyScripts")
	if oldGui then
		oldGui:Destroy()
	end


	local gui = Instance.new("ScreenGui")
	gui.Name = "GoofyScripts"
	gui.ResetOnSpawn = false
	gui.Parent = player.PlayerGui



	-- Main Frame

	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0,450,0,500)
	frame.Position = UDim2.new(0.5,-225,0.5,-250)
	frame.BackgroundColor3 = Color3.fromRGB(25,25,30)
	frame.BorderSizePixel = 0
	frame.Parent = gui


	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0,15)
	corner.Parent = frame


	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(140,0,255)
	stroke.Thickness = 3
	stroke.Parent = frame



	-- Title

	local title = Instance.new("TextLabel")
	title.Size = UDim2.new(1,-90,0,45)
	title.Position = UDim2.new(0,10,0,0)
	title.BackgroundTransparency = 1
	title.Text = "🤪 Goofy Scripts"
	title.TextColor3 = Color3.new(1,1,1)
	title.Font = Enum.Font.GothamBold
	title.TextSize = 24
	title.Parent = frame



	-- Close

	local close = Instance.new("TextButton")
	close.Size = UDim2.new(0,35,0,35)
	close.Position = UDim2.new(1,-40,0,5)
	close.Text = "X"
	close.BackgroundColor3 = Color3.fromRGB(220,60,60)
	close.TextColor3 = Color3.new(1,1,1)
	close.Parent = frame

	Instance.new("UICorner",close).CornerRadius = UDim.new(1,0)


	close.MouseButton1Click:Connect(function()
		gui:Destroy()
	end)



	-- Minimize

	local minimize = Instance.new("TextButton")
	minimize.Size = UDim2.new(0,35,0,35)
	minimize.Position = UDim2.new(1,-80,0,5)
	minimize.Text = "-"
	minimize.BackgroundColor3 = Color3.fromRGB(80,80,80)
	minimize.TextColor3 = Color3.new(1,1,1)
	minimize.Parent = frame

	Instance.new("UICorner",minimize).CornerRadius = UDim.new(1,0)


	local minimized = false
	local fullSize = frame.Size


	minimize.MouseButton1Click:Connect(function()

		minimized = not minimized

		if minimized then
			frame.Size = UDim2.new(0,450,0,50)
			minimize.Text = "+"
		else
			frame.Size = fullSize
			minimize.Text = "-"
		end

	end)



	-- Tabs

	local scriptTab = Instance.new("TextButton")
	scriptTab.Size = UDim2.new(.5,0,0,40)
	scriptTab.Position = UDim2.new(0,0,0,50)
	scriptTab.Text = "Scripts"
	scriptTab.BackgroundColor3 = Color3.fromRGB(0,170,255)
	scriptTab.TextColor3 = Color3.new(1,1,1)
	scriptTab.Parent = frame


	local controlTab = Instance.new("TextButton")
	controlTab.Size = UDim2.new(.5,0,0,40)
	controlTab.Position = UDim2.new(.5,0,0,50)
	controlTab.Text = "Controls"
	controlTab.BackgroundColor3 = Color3.fromRGB(80,80,80)
	controlTab.TextColor3 = Color3.new(1,1,1)
	controlTab.Parent = frame



	local scriptSection = Instance.new("Frame")
	scriptSection.Size = UDim2.new(1,-20,1,-110)
	scriptSection.Position = UDim2.new(0,10,0,100)
	scriptSection.BackgroundTransparency = 1
	scriptSection.Parent = frame


	local controlSection = Instance.new("Frame")
	controlSection.Size = UDim2.new(1,-20,1,-110)
	controlSection.Position = UDim2.new(0,10,0,100)
	controlSection.BackgroundTransparency = 1
	controlSection.Visible = false
	controlSection.Parent = frame



	scriptTab.MouseButton1Click:Connect(function()
		scriptSection.Visible = true
		controlSection.Visible = false
	end)


	controlTab.MouseButton1Click:Connect(function()
		scriptSection.Visible = false
		controlSection.Visible = true
	end)



	-- Speed System

	local speedEnabled = false
	local normalSpeed = 16


	local walkBox = Instance.new("TextBox")
	walkBox.Size = UDim2.new(.75,0,0,40)
	walkBox.Position = UDim2.new(.125,0,0,20)
	walkBox.Text = "50"
	walkBox.PlaceholderText = "Speed Amount"
	walkBox.BackgroundColor3 = Color3.fromRGB(60,60,65)
	walkBox.TextColor3 = Color3.new(1,1,1)
	walkBox.Parent = scriptSection

	Instance.new("UICorner",walkBox).CornerRadius = UDim.new(0,8)



	local speedButton = Instance.new("TextButton")
	speedButton.Size = UDim2.new(.75,0,0,40)
	speedButton.Position = UDim2.new(.125,0,0,70)
	speedButton.Text = "⚡ Speed: OFF (Z)"
	speedButton.BackgroundColor3 = Color3.fromRGB(60,60,65)
	speedButton.TextColor3 = Color3.new(1,1,1)
	speedButton.Parent = scriptSection

	Instance.new("UICorner",speedButton).CornerRadius = UDim.new(0,8)



	local function toggleSpeed()

		speedEnabled = not speedEnabled

		if speedEnabled then

			humanoid.WalkSpeed = tonumber(walkBox.Text) or 50
			speedButton.Text = "⚡ Speed: ON (Z)"
			speedButton.BackgroundColor3 = Color3.fromRGB(0,170,90)

		else

			humanoid.WalkSpeed = normalSpeed
			speedButton.Text = "⚡ Speed: OFF (Z)"
			speedButton.BackgroundColor3 = Color3.fromRGB(60,60,65)

		end
	speedButton.MouseButton1Click:Connect(function()
		toggleSpeed()
	end)



	-- Teleport

	local teleport = Instance.new("TextButton")
	teleport.Size = UDim2.new(.75,0,0,40)
	teleport.Position = UDim2.new(.125,0,0,125)
	teleport.Text = "📍 Teleport To Cursor (Q)"
	teleport.BackgroundColor3 = Color3.fromRGB(255,170,0)
	teleport.TextColor3 = Color3.new(1,1,1)
	teleport.Parent = scriptSection

	Instance.new("UICorner",teleport).CornerRadius = UDim.new(0,8)



	local function teleportToCursor()

		root.CFrame = CFrame.new(
			mouse.Hit.Position + Vector3.new(0,3,0)
		)

	end


	teleport.MouseButton1Click:Connect(function()
		teleportToCursor()
	end)



	-- Fly

	local flying = false
	local flySpeed = 50

	local bodyVelocity
	local bodyGyro

	local keys = {}



	local flyButton = Instance.new("TextButton")
	flyButton.Size = UDim2.new(.75,0,0,40)
	flyButton.Position = UDim2.new(.125,0,0,180)
	flyButton.Text = "✈ Fly: OFF (F)"
	flyButton.BackgroundColor3 = Color3.fromRGB(60,60,65)
	flyButton.TextColor3 = Color3.new(1,1,1)
	flyButton.Parent = scriptSection

	Instance.new("UICorner",flyButton).CornerRadius = UDim.new(0,8)



	local function toggleFly()

		flying = not flying


		if flying then

			bodyVelocity = Instance.new("BodyVelocity")
			bodyVelocity.MaxForce = Vector3.new(
				math.huge,
				math.huge,
				math.huge
			)
			bodyVelocity.Parent = root


			bodyGyro = Instance.new("BodyGyro")
			bodyGyro.MaxTorque = Vector3.new(
				math.huge,
				math.huge,
				math.huge
			)
			bodyGyro.P = 10000
			bodyGyro.Parent = root


			humanoid.PlatformStand = true


			flyButton.Text = "✈ Fly: ON (F)"
			flyButton.BackgroundColor3 = Color3.fromRGB(0,170,90)


		else

			if bodyVelocity then
				bodyVelocity:Destroy()
				bodyVelocity = nil
			end


			if bodyGyro then
				bodyGyro:Destroy()
				bodyGyro = nil
			end


			humanoid.PlatformStand = false


			flyButton.Text = "✈ Fly: OFF (F)"
			flyButton.BackgroundColor3 = Color3.fromRGB(60,60,65)

		end

	end



	flyButton.MouseButton1Click:Connect(function()
		toggleFly()
	end)




	-- Fly Speed Slider

	local speedLabel = Instance.new("TextLabel")
	speedLabel.Size = UDim2.new(1,0,0,30)
	speedLabel.Position = UDim2.new(0,0,0,235)
	speedLabel.BackgroundTransparency = 1
	speedLabel.Text = "Fly Speed: "..flySpeed
	speedLabel.TextColor3 = Color3.new(1,1,1)
	speedLabel.Font = Enum.Font.GothamBold
	speedLabel.TextSize = 18
	speedLabel.Parent = scriptSection



	local slider = Instance.new("Frame")
	slider.Size = UDim2.new(.75,0,0,12)
	slider.Position = UDim2.new(.125,0,0,275)
	slider.BackgroundColor3 = Color3.fromRGB(70,70,70)
	slider.Parent = scriptSection

	Instance.new("UICorner",slider).CornerRadius = UDim.new(1,0)



	local fill = Instance.new("Frame")
	fill.Size = UDim2.new(.15,0,1,0)
	fill.BackgroundColor3 = Color3.fromRGB(0,170,255)
	fill.Parent = slider

	Instance.new("UICorner",fill).CornerRadius = UDim.new(1,0)



	local sliderDragging = false

	local minFlySpeed = 10
	local maxFlySpeed = 300



	local function updateFlySlider(x)

		local percent = math.clamp(
			(x - slider.AbsolutePosition.X) /
			slider.AbsoluteSize.X,
			0,
			1
		)


		fill.Size = UDim2.new(percent,0,1,0)


		flySpeed = math.floor(
			minFlySpeed +
			(maxFlySpeed-minFlySpeed)*percent
		)


		speedLabel.Text = "Fly Speed: "..flySpeed

	end



	slider.InputBegan:Connect(function(input)

		if input.UserInputType == Enum.UserInputType.MouseButton1 then

			sliderDragging = true
			updateFlySlider(input.Position.X)

		end

	end)



	UserInputService.InputChanged:Connect(function(input)

		if sliderDragging and input.UserInputType == Enum.UserInputType.MouseMovement then

			updateFlySlider(input.Position.X)

		end

	end)



	UserInputService.InputEnded:Connect(function(input)

		if input.UserInputType == Enum.UserInputType.MouseButton1 then

			sliderDragging = false

		end

	end)
	-- Keybinds

	UserInputService.InputBegan:Connect(function(input, gameProcessed)

		if gameProcessed then return end


		if input.KeyCode == Enum.KeyCode.F then
			toggleFly()
		end


		if input.KeyCode == Enum.KeyCode.Z then
			toggleSpeed()
		end


		if input.KeyCode == Enum.KeyCode.Q then
			teleportToCursor()
		end

	end)



	-- Fly movement keys

	UserInputService.InputBegan:Connect(function(input)

		keys[input.KeyCode] = true

	end)



	UserInputService.InputEnded:Connect(function(input)

		keys[input.KeyCode] = false

	end)



	-- Fly movement

	RunService.RenderStepped:Connect(function()

		if flying and bodyVelocity and bodyGyro then

			local camera = workspace.CurrentCamera
			local move = Vector3.zero


			if keys[Enum.KeyCode.W] then
				move += camera.CFrame.LookVector
			end


			if keys[Enum.KeyCode.S] then
				move -= camera.CFrame.LookVector
			end


			if keys[Enum.KeyCode.A] then
				move -= camera.CFrame.RightVector
			end


			if keys[Enum.KeyCode.D] then
				move += camera.CFrame.RightVector
			end


			if keys[Enum.KeyCode.Space] then
				move += Vector3.new(0,1,0)
			end


			if keys[Enum.KeyCode.LeftControl] then
				move -= Vector3.new(0,1,0)
			end


			if move.Magnitude > 0 then
				move = move.Unit
			end


			bodyVelocity.Velocity = move * flySpeed
			bodyGyro.CFrame = camera.CFrame

		end

	end)



	-- Controls Tab

	local controls = Instance.new("TextLabel")
	controls.Size = UDim2.new(1,0,0,300)
	controls.Position = UDim2.new(0,0,0,20)
	controls.BackgroundTransparency = 1

	controls.Text =
		"⌨ KEYBINDS\n\n" ..
		"F = Toggle Fly\n\n" ..
		"Z = Toggle Speed\n\n" ..
		"Q = Teleport To Cursor\n\n" ..
		"WASD = Fly Movement\n\n" ..
		"SPACE = Fly Up\n\n" ..
		"CTRL = Fly Down\n\n" ..
		"Fly Speed Slider: 10-300"

	controls.TextColor3 = Color3.new(1,1,1)
	controls.Font = Enum.Font.GothamBold
	controls.TextSize = 20
	controls.Parent = controlSection




	-- Drag GUI

	local dragging = false
	local dragStart
	local startPos


	title.InputBegan:Connect(function(input)

		if input.UserInputType == Enum.UserInputType.MouseButton1 then

			dragging = true
			dragStart = input.Position
			startPos = frame.Position

		end

	end)



	UserInputService.InputEnded:Connect(function(input)

		if input.UserInputType == Enum.UserInputType.MouseButton1 then

			dragging = false

		end

	end)



	UserInputService.InputChanged:Connect(function(input)

		if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then

			local delta = input.Position - dragStart


			frame.Position = UDim2.new(

				startPos.X.Scale,
				startPos.X.Offset + delta.X,

				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y

			)

		end

	end)


end



-- Start GUI

createTool(player.Character or player.CharacterAdded:Wait())



-- Reload on respawn

player.CharacterAdded:Connect(function(character)

	task.wait(1)

	createTool(character)

end)
	end
